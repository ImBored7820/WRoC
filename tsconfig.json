{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./build", // also known as dist i like build more

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "ES2022",
    "target": "ES2022",
    "types": [],
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,

    // Custom (Mosh) * See my notes for Checkpoint 2 for ts (hour 4-5)
    "removeComments": true, // Removes comments from the output
    "noEmitOnError": true, // If error it tells you there's an error and doesnt build
    "noUnusedParameters": true, // Helps remove unused params
    "noUnusedLocals": true, // Same but for functions/objects
    "noImplicitReturns": true, // Cant return any
    //"strictNullChecks": false, // Allows null and undefined
  }
}
